{
  "expo": {
    "name": "falashi",
    "slug": "falashi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "O Falashi precisa do microfone para você responder os flashcards falando."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.c.jacon.falashi"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "25a2480f-a37f-4e24-9097-9e0aceab8669"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/25a2480f-a37f-4e24-9097-9e0aceab8669"
    },
    "plugins": [
      "expo-audio",
      "expo-sqlite"
    ]
  }
}
